{
	"name": "funnel-test-funnel",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "bun run policy:check && bun run typecheck && bun run build:client && bun run build:ssr && bun run prerender",
		"build:client": "vite build",
		"build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist-ssr",
		"prerender": "bun scripts/prerender.ts",
		"deploy": "bunx wrangler deploy",
		"deploy:preview": "bunx wrangler versions upload",
		"preview": "vite preview",
		"start": "vite preview",
		"policy:check": "bun policy/app-builder-policy.ts",
		"smoke": "bun policy/smoke-test.ts",
		"typecheck": "tsgo --noEmit",
		"format": "biome format --write .",
		"lint": "biome check .",
		"check": "biome check --write --unsafe ."
	},
	"dependencies": {
		"@octokit/app": "^16.1.2",
		"@octokit/rest": "^22.0.1",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.16.0",
		"motion": "^12.40.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"shiki": "^4.1.0",
		"svg-dotted-map": "^2.1.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/node": "^25.9.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260527.2",
		"@vitejs/plugin-react": "^6.0.2",
		"baseline-browser-mapping": "^2.10.32",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8"
	}
}